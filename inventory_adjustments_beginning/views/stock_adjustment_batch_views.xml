<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_opening_batch_form_view" model="ir.ui.view">
        <field name="name">stock.opening.batch.form</field>
        <field name="model">stock.opening.batch</field>
        <field name="arch" type="xml">
            <form string="Opening Balance Batch">
                <header>
                    <button name="action_simulasi_seluruh_produk" 
                            string="📊 Simulasi Massal" 
                            type="object" 
                            class="btn-secondary"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"/>

                    <button name="action_refresh_summary" 
                            type="object" 
                            string="Refresh Reconciliation" 
                            icon="fa-refresh"
                            class="oe_highlight"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            help="Hitung ulang Variance per Akun"/>
                    <button name="action_force_sync_date_after_validate" 
        string="🔄 Sync Date (Post-Done)" 
        type="object" 
        class="btn-warning"
        groups="inventory_adjustments_beginning.group_opening_batch_manager"
        attrs="{'invisible': [('state', '!=', 'done')]}"
        confirm="HATI-HATI: Ini akan memaksa tanggal seluruh transaksi (Gudang dan Akuntansi) ke tanggal header. Lanjut?"/>
                    <button name="action_basmi_hantu_final" 
                            string="👻 BASMI HANTU (DEEP CLEAN)" 
                            type="object" 
                            class="btn-warning"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            confirm="Kak, sistem akan men-scan selisih stok, menghapus Move/Lot sampah, dan membersihkan RAM Odoo secara total. Lanjut?"/>

                    <button name="action_purge_opening_lots_manual" 
                            string="🧹 Clean Planned Lots" 
                            type="object" 
                            class="btn-danger"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            confirm="HATI-HATI: Semua riwayat stok lama yang menggunakan Lot di daftar ini (berdasarkan nama di Reason) akan DIHAPUS PERMANEN agar Lot bisa dianggap baru. Lanjut?"/>

                    <button name="action_simulasi_nilai_final" 
                            string="🔍 Simulasi Nilai (Uji Asumsi)" 
                            type="object" 
                            class="btn-info"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"/>

                    <button name="action_recalculate_totals" 
                            string="Hitung Ulang Total" 
                            type="object" 
                            class="btn-secondary"
                            icon="fa-calculator"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            help="Klik jika total Target/Variance tidak update otomatis."/>

                    <button name="action_clear_lines"
                            type="object" string="Clear Lines"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            confirm="Yakin ingin menghapus semua baris?"/>

                    <button name="action_set_counts_to_zero"
                            type="object" string="Set Counts to Zero"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>

                    <button name="action_validate" type="object" string="Validate &amp; Post"
                            class="oe_highlight"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"
                            confirm="Pastikan Akun yang dicentang sudah Balance (Hijau). Lanjutkan?"/>

                    <button name="action_validate" type="object" string="Approve"
                            groups="inventory_adjustments_beginning.group_opening_batch_manager" 
                            class="oe_highlight"
                            attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>

                    <button name="action_request_approval" type="object" string="Request Approval"
                            class="oe_highlight"
                            attrs="{'invisible': ['|', ('state', '!=', 'draft'), ('is_stock_manager', '=', True)]}"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <field name="is_stock_manager" invisible="1"/>
                    
                    <div class="oe_title">
                        <widget name="web_ribbon" title="MATCHED" bg_color="bg-success"
                            attrs="{'invisible': [('reconciliation_status', '!=', 'balanced')]}"/>
                    
                        <widget name="web_ribbon" title="UNBALANCED" bg_color="bg-danger"
                            attrs="{'invisible': [('reconciliation_status', '!=', 'unbalanced')]}"/>
                        <h1><field name="name" attrs="{'readonly': [('state', '!=', 'draft')]}"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="journal_entry_id" options="{'no_create': True, 'no_open': False}"
                                   attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="manual_journal_ref" placeholder="Auto-fill from Journal"/>
                        </group>
                        
                        <group class="oe_subtotal_footer oe_right" col="2">
                            <div class="o_form_label">Reconciliation Status</div>
                            <field name="reconciliation_status"
                                widget="badge"
                                decoration-success="reconciliation_status == 'balanced'"
                                decoration-danger="reconciliation_status == 'unbalanced'"
                                decoration-warning="reconciliation_status == 'empty'"/>

                            <separator colspan="2"/>
                            <field name="total_inventory_value" widget="monetary"/>
                            <field name="total_active_target" widget="monetary" decoration-info="1"/>
                            <field name="total_active_variance" widget="monetary"
                                decoration-danger="total_active_variance != 0"
                                decoration-success="total_active_variance == 0"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" string="Lot Name / Reason" placeholder="Contoh: Saldo Awal 1 November 2025" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                    </group>
                    <notebook>
                        <page string="Adjustment Lines" name="adjustments">
                            <field name="line_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                                <tree editable="bottom">
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="product_category_id" optional="show"/>
                                    <field name="planned_debit_account_id" optional="hide"/>
                                    <field name="location_id" domain="[('usage', '=', 'internal')]"/>
                                    <field name="lot_id" domain="[('product_id', '=', product_id)]" context="{'default_product_id': product_id}" force_save="1"/>
                                    <field name="counted_qty"/>
                                    <field name="unit_cost"/>
                                    <field name="target_move_line_id" invisible="1"/>
                                    <field name="contra_account_id" optional="show" options="{'no_create': True}" force_save="1"/>
                                    <field name="inventory_value" sum="Total Inv Value"/>
                                    <field name="target_accounting_value" optional="hide"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Reconciliation Summary (Audit)" name="summary">
                            <div class="alert alert-info" role="alert" style="margin-bottom: 10px;">
                                1. Klik <b>"Refresh"</b> untuk hitung ulang.<br/>
                                2. Centang <b>"Override?"</b> jika ingin menimpa Jurnal Asli (Wajib Balance).<br/>
                                3. Hapus centang jika ingin mengabaikan selisih (Posting ke Gain/Loss).
                            </div>
                            
                            <field name="summary_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                                <tree editable="bottom" create="0" delete="0"
                                      decoration-danger="to_override and (variance &gt; 1 or variance &lt; -1)" 
                                      decoration-muted="not to_override"
                                      decoration-success="to_override and variance &gt;= -1 and variance &lt;= 1">
                                    <field name="to_override" widget="boolean_toggle" string="Override?" width="80px"/>
                                    <field name="account_id" readonly="1"/>
                                    <field name="inventory_value" sum="Total Fisik" readonly="1"/>
                                    <field name="journal_value" sum="Total Jurnal" readonly="1"/>
                                    <field name="variance" sum="Total Selisih" readonly="1"/>
                                    <field name="currency_id" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="stock_opening_batch_tree_view" model="ir.ui.view">
        <field name="name">stock.opening.batch.tree</field>
        <field name="model">stock.opening.batch</field>
        <field name="arch" type="xml">
            <tree string="Opening Batches" decoration-muted="state == 'cancel'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="journal_entry_id" optional="show"/>
                <field name="total_inventory_value" widget="monetary" optional="show"/>
                <field name="reconciliation_status" widget="badge" 
                       decoration-success="reconciliation_status == 'balanced'"
                       decoration-danger="reconciliation_status == 'unbalanced'"
                       optional="show"/>
                <field name="currency_id" invisible="1"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state in ('draft', 'in_progress')"/>
            </tree>
        </field>
    </record>

    <record id="action_stock_opening_batch" model="ir.actions.act_window">
        <field name="name">Opening Balance Batches</field>
        <field name="res_model">stock.opening.batch</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_stock_opening_batch_line" model="ir.actions.act_window">
        <field name="name">Import Lines Here</field>
        <field name="res_model">stock.opening.batch.line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_stock_opening_batch"
        name="Opening Balance Batches"
        action="action_stock_opening_batch"
        parent="stock.menu_stock_warehouse_mgmt"
        sequence="18"/>

    <menuitem
        id="menu_stock_opening_batch_line"
        name="Import Lines Here"
        action="action_stock_opening_batch_line"
        parent="stock.menu_stock_warehouse_mgmt"
        sequence="19"/>

</odoo>