<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="hide_login_logo"
              inherit_id="web.login_layout">

        <xpath expr="//div[@class='card-body']/div[1]"
               position="replace">

            <t t-if="request.env.company.show_login_logo">

                <div t-attf-class="text-center pb-3 border-bottom {{'mb-3' if form_small else 'mb-4'}}" style="min-height:80px;">

                    <img t-if="request.env.company.show_login_logo"
                        t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                        alt="Logo"
                        style="max-height:120px; max-width:100%; width:auto"/>

                </div>

            </t>

        </xpath>

    </template>

</odoo>