<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="generate_batches_wizard_form_view" model="ir.ui.view">
        <field name="name">generate.batches.wizard.form</field>
        <field name="model">generate.batches.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Count Batches">
                <group>
                    <group>
                        <field name="batch_name_prefix"/>
                        <field name="location_id"/>
                        <field name="max_lines_per_batch"/>
                    </group>
                    <group>
                        <field name="group_by_field" widget="radio"/>
                        <field name="filter_type" widget="radio"/>
                        <field name="product_categ_id"
                            attrs="{'invisible': [('filter_type', '!=', 'category')], 'required': [('filter_type', '=', 'category')]}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_batches" string="Generate Batches" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_generate_batches_wizard" model="ir.actions.act_window">
        <field name="name">Generate Count Batches</field>
        <field name="res_model">generate.batches.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>