<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="sale_order_form_stock_status" model="ir.ui.view">
        <field name="name">sale.order.form.stock.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Ribbon -->

            <xpath expr="//sheet/div[@class='oe_button_box']" position="after">
                <field name="availability_status" invisible="1"/>

                <widget name="web_ribbon"
                        title="AVAILABLE"
                        bg_color="bg-success"
                        attrs="{'invisible':[('availability_status','!=','available')]}"/>
                
                <widget name="web_ribbon"
                        title="PARTIAL AVAILABLE"
                        bg_color="bg-warning"
                        attrs="{'invisible':[('availability_status','!=','partial_available')]}"/>
                
                <widget name="web_ribbon"
                        title="PARTIAL RESERVED"
                        bg_color="bg-info"
                        attrs="{'invisible':[('availability_status','!=','partial_reserved')]}"/>
                
                <widget name="web_ribbon"
                        title="RESERVED"
                        bg_color="bg-info"
                        attrs="{'invisible':[('availability_status','!=','reserved')]}"/>

                <widget name="web_ribbon"
                        title="DONE"
                        bg_color="bg-success"
                        attrs="{'invisible':[('availability_status','!=','done')]}"/>
                
                <widget name="web_ribbon"
                        title="OUT OF STOCK"
                        bg_color="bg-danger"
                        attrs="{'invisible':[('availability_status','!=','unavailable')]}"/>

            </xpath>
            
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <!-- <field name="stock_status" optional="show"/> -->
                <field name="stock_status"
                    widget="badge"
                    decoration-success="stock_status in ('available', 'done')"
                    decoration-warning="stock_status == 'partial_available'"
                    decoration-primary="stock_status == 'partial_reserved'"
                    decoration-info="stock_status == 'reserved'"
                    decoration-danger="stock_status == 'unavailable'"/>
            </xpath>

        </field>

    </record>

</odoo>