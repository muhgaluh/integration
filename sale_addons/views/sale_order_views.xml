<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="sale_order_form_stock_status" model="ir.ui.view">
        <field name="name">sale.order.form.stock.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Ribbon -->

            <xpath expr="//sheet/div[@class='oe_button_box']" position="after">
                <field name="availability_status" invisible="1"/>
        
                <widget name="web_ribbon"
                        title="QUOTATION"
                        bg_color="bg-info"
                        attrs="{'invisible':[('availability_status','!=','quotation')]}"/>
        
                <widget name="web_ribbon"
                        title="QUOTATION SENT"
                        bg_color="bg-info"
                        attrs="{'invisible':[('availability_status','!=','quotation_sent')]}"/>
        
                <widget name="web_ribbon"
                        title="SALES ORDER"
                        bg_color="bg-primary"
                        attrs="{'invisible':[('availability_status','!=','sales_order')]}"/>
        
                <widget name="web_ribbon"
                        title="DONE"
                        bg_color="bg-success"
                        attrs="{'invisible':[('availability_status','!=','done')]}"/>

                <widget name="web_ribbon"
                        title="CANCELLED"
                        bg_color="bg-danger"
                        attrs="{'invisible':[('availability_status','!=','cancelled')]}"/>

            </xpath>
            
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_uom_qty']" position="after">
                <!-- <field name="stock_status" optional="show"/> -->
                <field name="stock_status"
                    widget="badge"
                    decoration-success="stock_status in ('available', 'done')"
                    decoration-warning="stock_status == 'partial_available'"
                    decoration-primary="stock_status == 'partial_reserved'"
                    decoration-info="stock_status == 'reserved'"
                    decoration-danger="stock_status in ('cancelled', 'unavailable')"/>
            </xpath>

        </field>

    </record>

</odoo>