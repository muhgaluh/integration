<odoo>
    <record id="view_picking_form_insw" model="ir.ui.view">
        <field name="name">stock.picking.form.insw</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_insw_queue" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-globe" 
                        attrs="{'invisible': [('insw_queue_count', '=', 0)]}">
                    <field name="insw_queue_count" widget="statinfo" string="INSW"/>
                </button>
            </xpath>

            <xpath expr="//div[@class='oe_title']" position="before">
                <widget name="web_ribbon" title="INSW SENT" bg_color="bg-success" attrs="{'invisible': [('insw_status', '!=', 'sent')]}"/>
                <widget name="web_ribbon" title="INSW ERROR" bg_color="bg-danger" attrs="{'invisible': [('insw_status', '!=', 'error')]}"/>
                <widget name="web_ribbon" title="INSW DRAFT" bg_color="bg-warning" attrs="{'invisible': [('insw_status', '!=', 'draft')]}"/>
            </xpath>
            
            <xpath expr="//header" position="inside">
                <button name="action_create_insw_queue" string="Buat Antrian INSW" type="object" 
                        attrs="{'invisible': ['|', ('state', '!=', 'done'), ('insw_status', '!=', False)]}" 
                        groups="stock.group_stock_manager"/>
            </xpath>

            <xpath expr="//field[@name='origin']" position="after">
                <field name="insw_status" invisible="1"/>
            </xpath>
        </field>
    </record>
    <record id="view_picking_tree_insw" model="ir.ui.view">
        <field name="name">stock.picking.tree.insw</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="insw_status" widget="badge" 
                       decoration-success="insw_status == 'sent'" 
                       decoration-danger="insw_status == 'error'" 
                       decoration-warning="insw_status == 'draft'"
                       optional="show"/>
            </field>
        </field>
    </record>
</odoo>